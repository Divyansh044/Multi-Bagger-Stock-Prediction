.tox/
.nox/
.coverage
.coverage.*
coverage.xml
*.cover
htmlcov/
.pytest_cache/
.hypothesis/
nosetests.xml

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json
.pyright/

